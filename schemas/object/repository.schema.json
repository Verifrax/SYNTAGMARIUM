{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verifrax.net/schemas/object/repository.schema.json",
  "title": "Repository",
  "type": "object",
  "additionalProperties": false,
  "required": ["repo_id","primary_role","default_branch","license","hosts","packages","status"],
  "properties": {
    "repo_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "primary_role": { "type": "string" },
    "default_branch": { "type": "string", "const": "main" },
    "license": { "type": "string", "const": "Apache-2.0" },
    "hosts": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "packages": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "status": { "type": "string", "enum": ["active","historical","quarantined"] }
  }
}
