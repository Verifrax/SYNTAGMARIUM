{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verifrax.net/schemas/object/host.schema.json",
  "title": "Host",
  "type": "object",
  "additionalProperties": false,
  "required": ["fqdn","host_class","role","owning_repo","required_adjacent_links"],
  "properties": {
    "fqdn": { "type": "string" },
    "host_class": { "type": "string" },
    "role": { "type": "string" },
    "owning_repo": { "type": "string" },
    "required_adjacent_links": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
