{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verifrax.net/schemas/object/package.schema.json",
  "title": "Package",
  "type": "object",
  "additionalProperties": false,
  "required": ["package_name","source_repo","license","visibility","status"],
  "properties": {
    "package_name": { "type": "string" },
    "source_repo": { "type": "string" },
    "license": { "type": "string", "const": "Apache-2.0" },
    "visibility": { "type": "string", "enum": ["public","private","absent"] },
    "status": { "type": "string", "enum": ["active","historical","quarantined"] }
  }
}
