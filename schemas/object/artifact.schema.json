{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verifrax.net/schemas/object/artifact.schema.json",
  "title": "Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id","state","current_truth_surfaces","historical_surfaces"],
  "properties": {
    "artifact_id": { "type": "string" },
    "state": { "type": "string", "enum": ["UNVERIFIED","VERIFIED","QUARANTINED","HISTORICAL"] },
    "current_truth_surfaces": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "historical_surfaces": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
