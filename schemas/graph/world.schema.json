{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorldGraph",
  "type": "object",
  "required": [
    "law_version",
    "nodes",
    "edges"
  ],
  "properties": {
    "law_version": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}
